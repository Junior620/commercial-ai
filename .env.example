# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Webhooks : URL publique https://VOTRE_DOMAINE/api/webhooks/resend (Resend > Webhooks)
# + activer le suivi d'ouverture : Resend > Domains > votre domaine > Configuration > Open tracking
# (sans cela, email.opened n'est pas emis ; en local, utiliser ngrok ou deployer)

# Apify
APIFY_API_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Sender identity (used in AI email generation + signature)
SENDER_NAME=Your Name
SENDER_POSITION=Your Position
SENDER_COMPANY=Your Company
SENDER_PHONE=+xxx xxx xxx xxx
SENDER_WEBSITE=https://yourcompany.com
# Optional: absolute logo URL for email signature (fallback: NEXT_PUBLIC_APP_URL/logo.png)
SENDER_LOGO_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
