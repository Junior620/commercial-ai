# pnpm : hoister proxy-agent (et amis) au top-level de node_modules afin que
# Vercel/@vercel/nft puisse les embarquer dans la Lambda sans dependre du store
# virtuel .pnpm/ (qui contient des liens symboliques refuses par Vercel).
public-hoist-pattern[]=*proxy-agent*
public-hoist-pattern[]=@apify/*
